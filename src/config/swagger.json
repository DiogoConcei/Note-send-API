{
  "openapi": "3.0.0",
  "info": {
    "title": "Note Send API",
    "version": "1.0.0",
    "description": "API segura para gerenciamento de notas com login híbrido (Manual + Google)"
  },
  "servers": [
    {
      "url": "/api",
      "description": "Servidor Atual (Relativo)"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Note": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "title": { "type": "string" },
          "content": { "type": "string" },
          "userId": { "type": "integer" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "email": { "type": "string" },
          "name": { "type": "string" }
        }
      }
    }
  },
  "paths": {
    "/auth/register": {
      "post": {
        "tags": ["Autenticação"],
        "summary": "Registro de novo usuário",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password", "name"],
                "properties": {
                  "email": { "type": "string", "example": "user@example.com" },
                  "password": { "type": "string", "example": "senha123" },
                  "name": { "type": "string", "example": "João Silva" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Usuário registrado com sucesso" },
          "400": { "description": "E-mail já cadastrado ou dados inválidos" }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["Autenticação"],
        "summary": "Login manual",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Login realizado" },
          "401": { "description": "Credenciais inválidas" }
        }
      }
    },
    "/auth/google": {
      "post": {
        "tags": ["Autenticação"],
        "summary": "Login via Google",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["idToken"],
                "properties": {
                  "idToken": { "type": "string", "description": "Token recebido do Google no Frontend" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Login realizado via Google" },
          "401": { "description": "Token inválido" }
        }
      }
    },
    "/notes": {
      "get": {
        "tags": ["Notas"],
        "summary": "Retorna as notas do usuário logado",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Lista de notas",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Note" } }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Notas"],
        "summary": "Cria uma nova nota",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["title", "content"],
                "properties": {
                  "title": { "type": "string" },
                  "content": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Nota criada" }
        }
      }
    },
    "/notes/{id}": {
      "get": {
        "tags": ["Notas"],
        "summary": "Retorna uma nota específica",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Nota encontrada" },
          "404": { "description": "Nota não encontrada" }
        }
      },
      "put": {
        "tags": ["Notas"],
        "summary": "Atualiza uma nota",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": { "type": "string" },
                  "content": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Nota atualizada" },
          "404": { "description": "Nota não encontrada" }
        }
      },
      "delete": {
        "tags": ["Notas"],
        "summary": "Remove uma nota",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "204": { "description": "Nota removida" }
        }
      }
    }
  }
}
